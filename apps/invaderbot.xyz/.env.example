# Neynar API for Farcaster data
NEYNAR_API_KEY=your_neynar_api_key_here
INVADERBOT_FID=your_farcaster_fid_here

# Anthropic Claude API for AI chat integration
ANTHROPIC_API_KEY=your_claude_api_key_here

# OpenSea API for NFT metadata (optional - works without key but with rate limits)
OPENSEA_API_KEY=your_opensea_api_key_here

# WalletConnect Project ID for Web3 wallet integration
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Public OpenSea API key for client-side purchase functionality
NEXT_PUBLIC_OPENSEA_API_KEY=your_opensea_api_key_here