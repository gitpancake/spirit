{
  "name": "contract-listener",
  "version": "1.0.0",
  "description": "Production-ready contract event listener with webhook notifications",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ethereum",
    "smart-contracts",
    "websocket",
    "viem",
    "webhook"
  ],
  "dependencies": {
    "viem": "^2.21.1",
    "ws": "^8.18.0",
    "axios": "^1.7.7",
    "zod": "^3.23.8",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "@types/ws": "^8.5.12",
    "@types/express": "^4.17.21",
    "@typescript-eslint/eslint-plugin": "^8.4.0",
    "@typescript-eslint/parser": "^8.4.0",
    "eslint": "^9.9.1",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/contract-listener.git"
  },
  "license": "MIT"
}