# Blockchain RPC Configuration
RPC_URL=https://eth-mainnet.ws.alchemyapi.io/v2/your-api-key
RPC_HTTP_URL=https://eth-mainnet.alchemyapi.io/v2/your-api-key
CHAIN_ID=1

# Contract Configuration
CONTRACT_ADDRESS=0x...
CONTRACT_START_BLOCK=18000000

# Webhook Configuration
WEBHOOK_URL=https://your-vercel-app.com/api/webhooks/agent-registry
WEBHOOK_SECRET=your-webhook-secret
CACHE_API_URL=https://your-vercel-app.com/api/cache/tokens

# Application Configuration
NODE_ENV=production
LOG_LEVEL=info
PORT=3000

# WebSocket Configuration
WS_PING_INTERVAL=30000
WS_PONG_TIMEOUT=5000
WS_RECONNECT_DELAY=5000
WS_MAX_RECONNECT_ATTEMPTS=10

# Retry Configuration
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY=1000
WEBHOOK_TIMEOUT=10000

# Initial Sync Configuration
INITIAL_SYNC_ENABLED=true
INITIAL_SYNC_BLOCK_RANGE=499