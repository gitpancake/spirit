# Environment Configuration
NODE_ENV=development # development | production

# Network Configuration
CHAIN_ID=84532 # 84532 = Base Sepolia, 8453 = Base Mainnet
RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Alchemy Configuration
ALCHEMY_API_KEY=your_alchemy_api_key_here

# Contract Addresses
MINTER_CONTRACT_ADDRESS=0x... # FixedPriceManifestoMinter contract address

# Wallet Configuration (KEEP SECURE!)
DISTRIBUTOR_PRIVATE_KEY=0x... # Private key for wallet that will call distribute()

# Monitoring Configuration
POLL_INTERVAL_MS=5000 # How often to check for new events (milliseconds)
MAX_RETRIES=3 # Maximum number of retries for failed transactions
RETRY_DELAY_MS=2000 # Delay between retries (milliseconds)

# Gas Configuration
GAS_LIMIT=500000 # Gas limit for distribute transactions
MAX_FEE_PER_GAS= # Optional: Max fee per gas in gwei
MAX_PRIORITY_FEE_PER_GAS= # Optional: Max priority fee in gwei

# Logging Configuration
LOG_LEVEL=info # trace | debug | info | warn | error | fatal
LOG_PRETTY=true # Pretty print logs in development
