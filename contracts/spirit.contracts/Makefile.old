# =============================
# Solienne Manifesto System
# =============================

# ERC-1155 versions (default - recommended for newsletter use case)
deploy-solienne-manifesto: check-env
	@echo "✨ Deploying Solienne Manifesto (ERC-1155) to $(NETWORK)..."
	@echo "📰 Newsletter-optimized: 88% gas savings vs ERC-721"
	@NAME_VAL="$(if $(MANIFESTO_NAME),$(MANIFESTO_NAME),Solienne Manifesto)"; \
	SYMBOL_VAL="$(if $(MANIFESTO_SYMBOL),$(MANIFESTO_SYMBOL),MANIFESTO)"; \
	echo ""; \
	echo "Deploying with:"; \
	echo "  Name: $$NAME_VAL"; \
	echo "  Symbol: $$SYMBOL_VAL"; \
	echo ""
	@MANIFESTO_NAME="$(if $(MANIFESTO_NAME),$(MANIFESTO_NAME),Solienne Manifesto)" \
	MANIFESTO_SYMBOL="$(if $(MANIFESTO_SYMBOL),$(MANIFESTO_SYMBOL),MANIFESTO)" \
	$(if $(MANIFESTO_OWNER),MANIFESTO_OWNER=$(MANIFESTO_OWNER)) \
	forge script script/DeploySolienneManifesto.s.sol:DeploySolienneManifesto \
		--rpc-url $(NETWORK) \
		--broadcast \
		$(AUTH_FLAGS) \
		--verify \
		-vvvv
	@echo "✅ Manifesto deployment complete!"
	$(call log-deployment,SolienneManifesto)

deploy-solienne-minter: check-env
	@echo "🏪 Deploying Fixed Price Manifesto Minter (ERC-1155) to $(NETWORK)..."
	@echo "📰 Newsletter-optimized: Native batch operations + USDC payments"
	@echo "💰 Default Payout: 0xD5090Df0a9Ec491E95fe21ddE7B5E4868F852874 (override with PAYOUT_ADDRESS env var)"
	@if [ "$(MANIFESTO_CONTRACT)" = "" ]; then \
		echo "❌ Error: Please specify MANIFESTO_CONTRACT address"; \
		echo "💡 Usage: make deploy-solienne-minter MANIFESTO_CONTRACT=0x... NETWORK=$(NETWORK)"; \
		exit 1; \
	fi
	@if [ "$(NETWORK)" = "base" ]; then \
		USDC_TOKEN=$(USDC_BASE_MAINNET); \
	elif [ "$(NETWORK)" = "base-sepolia" ]; then \
		USDC_TOKEN=$(USDC_BASE_SEPOLIA); \
	elif [ "$(USDC_TOKEN)" = "" ]; then \
		echo "❌ Error: USDC_TOKEN must be set for network $(NETWORK)"; \
		echo "💡 For Base: $(USDC_BASE_MAINNET)"; \
		echo "💡 For Base Sepolia: $(USDC_BASE_SEPOLIA)"; \
		exit 1; \
	fi; \
	OWNER_VAL=$$(npx hardhat run --network $(NETWORK) scripts/get-deployer-address.js 2>/dev/null | tail -1); \
	PAYOUT_VAL="$(if $(PAYOUT_ADDRESS),$(PAYOUT_ADDRESS),0xD5090Df0a9Ec491E95fe21ddE7B5E4868F852874)"; \
	node scripts/table-helper.js deployment solienne-minter \
		"$(NETWORK)" \
		"$$OWNER_VAL" \
		"$$PAYOUT_VAL" \
		"$(MANIFESTO_CONTRACT)" \
		"$$USDC_TOKEN"
	@echo ""
	@if [ "$(NETWORK)" = "base" ]; then \
		USDC_TOKEN=$(USDC_BASE_MAINNET); \
	elif [ "$(NETWORK)" = "base-sepolia" ]; then \
		USDC_TOKEN=$(USDC_BASE_SEPOLIA); \
	fi; \
	OWNER_VAL=$$(npx hardhat run --network $(NETWORK) scripts/get-deployer-address.js 2>/dev/null | tail -1); \
	PAYOUT_VAL="$(if $(PAYOUT_ADDRESS),$(PAYOUT_ADDRESS),0xD5090Df0a9Ec491E95fe21ddE7B5E4868F852874)"; \
	MANIFESTO_CONTRACT=$(MANIFESTO_CONTRACT) USDC_TOKEN=$$USDC_TOKEN HARDHAT_NETWORK=$(NETWORK) MINTER_OWNER=$$OWNER_VAL PAYOUT_ADDRESS=$$PAYOUT_VAL \
	npx hardhat ignition deploy ignition/modules/Solienne/DeploySolienneMinter.ts --deployment-id SolienneMinter-$(shell date +%s) --network $(NETWORK) --verify || true
	@node scripts/table-helper.js completion solienne-minter
	$(call log-deployment,SolienneMinter)

