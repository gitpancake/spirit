deploy-solienne-minter-v3: check-env
	@echo "🚀 Deploying Fixed Price Manifesto Minter V3 (ERC-1155 + Flexible Distribution) to $(NETWORK)..."
	@echo "📦 NEW: Flexible distributeToSubscribersBatch() - No subscription check"
	@echo "🎯 Admin has full control over recipient list for batch distribution"
	@echo "💎 Use Cases: Airdrops, partnerships, promotional campaigns, any custom distribution"
	@echo ""
	@if [ "$(MANIFESTO_CONTRACT)" = "" ]; then \
		echo "❌ Error: Please specify MANIFESTO_CONTRACT address"; \
		echo "💡 Usage: make deploy-solienne-minter-v3 MANIFESTO_CONTRACT=0x... NETWORK=$(NETWORK)"; \
		exit 1; \
	fi
	@if [ "$(NETWORK)" = "base" ]; then \
		USDC_TOKEN=$(USDC_BASE_MAINNET); \
	elif [ "$(NETWORK)" = "base-sepolia" ]; then \
		USDC_TOKEN=$(USDC_BASE_SEPOLIA); \
	elif [ "$(USDC_TOKEN)" = "" ]; then \
		echo "❌ Error: USDC_TOKEN must be set for network $(NETWORK)"; \
		echo "💡 For Base: $(USDC_BASE_MAINNET)"; \
		echo "💡 For Base Sepolia: $(USDC_BASE_SEPOLIA)"; \
		exit 1; \
	fi; \
	PAYOUT_VAL="$(if $(PAYOUT_ADDRESS),$(PAYOUT_ADDRESS),0xD5090Df0a9Ec491E95fe21ddE7B5E4868F852874)"; \
	echo ""; \
	echo "Deploying with:"; \
	echo "  Manifesto: $(MANIFESTO_CONTRACT)"; \
	echo "  USDC Token: $$USDC_TOKEN"; \
	echo "  Payout: $$PAYOUT_VAL"; \
	echo ""
	@if [ "$(NETWORK)" = "base" ]; then \
		USDC_TOKEN=$(USDC_BASE_MAINNET); \
	elif [ "$(NETWORK)" = "base-sepolia" ]; then \
		USDC_TOKEN=$(USDC_BASE_SEPOLIA); \
	fi; \
	MANIFESTO_CONTRACT=$(MANIFESTO_CONTRACT) \
	USDC_TOKEN=$$USDC_TOKEN \
	$(if $(MINTER_OWNER),MINTER_OWNER=$(MINTER_OWNER)) \
	PAYOUT_ADDRESS="$(if $(PAYOUT_ADDRESS),$(PAYOUT_ADDRESS),0xD5090Df0a9Ec491E95fe21ddE7B5E4868F852874)" \
	forge script script/DeploySolienneMinterV3.s.sol:DeploySolienneMinterV3 \
		--rpc-url $(NETWORK) \
		--broadcast \
		$(AUTH_FLAGS) \
		--verify \
		-vvvv
	@echo ""
	@echo "✅ Fixed Price Manifesto Minter V3 deployment complete!"
	@echo ""
	@echo "📋 Next Steps:"
	@echo "   1. Authorize V3 minter on Manifesto NFT:"
	@echo "      cast send $(MANIFESTO_CONTRACT) \"updateMinter(address)\" <MINTER_V3_ADDRESS>"
	@echo ""
	@echo "   2. Test flexible batch distribution (no subscription check):"
	@echo "      cast send <MINTER_V3_ADDRESS> \"distributeToSubscribersBatch(address[],uint256)\" \"[0xAddr1,0xAddr2]\" 1"
	@echo ""
	@echo "   3. Update frontend with new contract address and ABI"
	@echo ""
	@echo "📚 V3 Changelog: Removed subscription status check from distributeToSubscribersBatch()"
	$(call log-deployment,SolienneMinterV3)

