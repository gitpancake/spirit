# SPIRIT/EDEN Makefile
#
# This Makefile provides common development and deployment tasks
# for the SPIRIT/EDEN project

.PHONY: install-deps update-deps compile clean format lint test coverage gas-report help list-deployments check-env deploy-status show-addresses
.PHONY: deploy-distributor deploy-auction deploy-auction-testing deploy-auction-interactive deploy-auction-abraham deploy-auction-henry manage-auction manage-agent-registry deploy-test-nft deploy-fixed-supply-erc20 deploy-spirit deploy-spirit-vesting
.PHONY: deploy-supertoken-complete deploy-supertoken-configurable deploy-supertoken-simple deploy-supertoken-only deploy-distribution-pool-only deploy-agent-registry deploy-spirit-registry deploy-agent-identity-registry
.PHONY: deploy-abraham-complete
.PHONY: deploy-gov-token deploy-timelock deploy-governor deploy-governance-complete
.PHONY: interact-pool check-pool-status start-revenue-flow real-world-scenarios learn-eth-distribution
.PHONY: deploy-first-works-production-mainnet deploy-first-works-production-testnet
.PHONY: deploy-solienne-manifesto deploy-solienne-minter deploy-solienne-minter-v2 deploy-solienne-minter-v3 deploy-mock-usdc
.PHONY: deploy-solienne-genesis-portraits deploy-solienne-origin-series deploy-solienne-fixed-price-minter
.PHONY: deploy-gepetto-toys

# Default network
NETWORK="sepolia"

# USDC contract addresses
USDC_BASE_MAINNET := 0x833589fcd6edb6e08f4c7c32d4f71b54bda02913
USDC_BASE_SEPOLIA := 0x67aEBee687A479cbd07CC7648df21403D0C1a4B3

# =============================
# Foundry Keystore Authentication
# =============================
# For secure deployments, use Foundry's encrypted keystore instead of plain text private keys
#
# Setup (one-time):
#   cast wallet import <account-name> --interactive
#   (Enter your private key when prompted, then set a password)
#
# Usage with keystore:
#   make deploy-solienne-origin-series ACCOUNT=<account-name> SENDER=0xYourAddress NETWORK=base-sepolia
#
# Usage with .env PRIVATE_KEY (less secure):
#   make deploy-solienne-origin-series NETWORK=base-sepolia
#
# If ACCOUNT is set, uses encrypted keystore. Otherwise falls back to PRIVATE_KEY from .env

# Construct authentication flags based on whether ACCOUNT is provided
ifdef ACCOUNT
    ifndef SENDER
        $(error SENDER address must be provided when using ACCOUNT. Usage: make deploy ACCOUNT=myaccount SENDER=0xYourAddress)
    endif
    AUTH_FLAGS := --account $(ACCOUNT) --sender $(SENDER)
else
    AUTH_FLAGS :=
endif

# Common paths
IGNITION_BASE_PATH=./ignition/modules
DISTRIBUTOR_PATH=./ignition/modules/Distributor
NFT_PATH=./ignition/modules/NFT
ERC20_PATH=./ignition/modules/ERC20
SPIRIT_PATH=./ignition/modules/Spirit
SPIRIT_VESTING_PATH = ./ignition/modules/Invaders
SUPERTOKEN_PATH=./ignition/modules/SuperTokens
DEPLOYMENT_LOGS_DIR=./deployment-logs

# =============================
# Installation & Setup
# =============================

install-deps:
	@echo "Installing dependencies..."
	@npm ci
	@echo "Dependencies installed successfully."

update-deps:
	@echo "Updating dependencies..."
	@npm update
	@echo "Dependencies updated successfully."

# =============================
# Building & Compilation
# =============================

compile:
	@echo "Compiling contracts with Foundry..."
	@forge build
	@echo "Compilation completed successfully."

clean:
	@echo "Cleaning build artifacts..."
	@forge clean
	@echo "Clean completed successfully."

verify:
	@echo "Verifying contracts..."
	@forge verify-contract $(CONTRACT_ADDRESS) $(CONTRACT_NAME) --chain $(NETWORK) --watch
	@echo "Verification completed successfully."

# =============================
# Testing
# =============================

node:
	@echo "Starting Hardhat node in background..."
	@nohup npx hardhat node > node.log 2>&1 & echo $$! > .node_pid
	@sleep 3 # give it a few seconds to start

test:
	@echo "Running tests with background node..."
	@bash -c ' \
		make node && \
		npm run test -- --network localhost && \
		make stop-node \
	'
	@echo "Tests completed with node shutdown."

test-supertoken:
	@echo "Running SuperToken tests with background node..."
	@bash -c ' \
		make node && \
		npx hardhat test test/SuperTokens/PureSuperTokenWithPool.test.ts --network localhost && \
		make stop-node \
	'
	@echo "SuperToken tests completed with node shutdown."

stop-node:
	@echo "Stopping Hardhat node..."
	@kill `cat .node_pid` && rm .node_pid

coverage:
	@echo "Generating coverage report..."
	@npm run coverage
	@echo "Coverage report generated."

gas-report:
	@echo "Generating gas report..."
	@npm run gas-report
	@echo "Gas report generated."

# =============================
# Code Quality
# =============================

format:
	@echo "Formatting code..."
	@npm run format
	@echo "Formatting completed."

lint:
	@echo "Linting code..."
	@npm run lint
	@echo "Linting completed."

