	GENESIS_ROYALTY_RECEIVER="$(if $(GENESIS_ROYALTY_RECEIVER),$(GENESIS_ROYALTY_RECEIVER),0xeee98E09620182Be55E5eCD6D20C22aB3697D5f2)" \
	GENESIS_ROYALTY_FEE="$(if $(GENESIS_ROYALTY_FEE),$(GENESIS_ROYALTY_FEE),500)" \
