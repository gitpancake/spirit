		"$(NETWORK)" \
		"$$OWNER_VAL" \
		"$$PAYOUT_VAL" \
		"$(MANIFESTO_CONTRACT)" \
		"$$USDC_TOKEN"
	@echo ""
	@if [ "$(NETWORK)" = "base" ]; then \
		USDC_TOKEN=$(USDC_BASE_MAINNET); \
	elif [ "$(NETWORK)" = "base-sepolia" ]; then \
		USDC_TOKEN=$(USDC_BASE_SEPOLIA); \
	fi; \
	OWNER_VAL=$$(npx hardhat run --network $(NETWORK) scripts/get-deployer-address.js 2>/dev/null | tail -1); \
