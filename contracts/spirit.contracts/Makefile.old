	@echo ""
	@COVENANT_VAL="$(if $(COVENANT),$(COVENANT),$(if $(ABRAHAM_COVENANT_ADDRESS),$(ABRAHAM_COVENANT_ADDRESS),$(if $(filter ethereum mainnet,$(NETWORK)),0x8f814c7c75c5e9e0ede0336f535604b1915c1985,0x369AE5f781b5bFb3f25520E0e3e2DA56Be3A3f48)))"; \
