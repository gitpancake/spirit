deploy-abraham-covenant: check-env
	@echo "📜 Deploying AbrahamCovenant NFT contract to $(NETWORK) (PRODUCTION)"
	@echo ""
	@. ./.env 2>/dev/null || true; \
	DEPLOYER_ADDRESS=$$(npx hardhat run --network $(NETWORK) scripts/get-deployer-address.js 2>/dev/null | tail -1); \
	DEFAULT_ABRAHAM="$(if $(filter sepolia,$(NETWORK)),$$DEPLOYER_ADDRESS,0x641f5ffC5F6239A0873Bd00F9975091FB035aAFC)"; \
	DEFAULT_OWNER="$(if $(filter sepolia,$(NETWORK)),$$DEPLOYER_ADDRESS,0xe8b21Cb49918C4A6513F0E398b4cf7087e9CBFAD)"; \
	ABRAHAM_VAL="$(if $(ABRAHAM_ADDRESS),$(ABRAHAM_ADDRESS),$$DEFAULT_ABRAHAM)"; \
	OWNER_VAL="$(if $(ABRAHAM_OWNER),$(ABRAHAM_OWNER),$$DEFAULT_OWNER)"; \
	MAX_SUPPLY_VAL="$(if $(ABRAHAM_MAX_SUPPLY),$(ABRAHAM_MAX_SUPPLY),4074)"; \
	DAYS_WORK_VAL="$(if $(ABRAHAM_DAYS_OF_WORK),$(ABRAHAM_DAYS_OF_WORK),6)"; \
	DEFAULT_INTERVAL="$(if $(filter sepolia,$(NETWORK)),60,86400)"; \
	INTERVAL_VAL="$(if $(ABRAHAM_COMMIT_INTERVAL),$(ABRAHAM_COMMIT_INTERVAL),$$DEFAULT_INTERVAL)"; \
	NAME_VAL="$(if $(ABRAHAM_NAME),$(ABRAHAM_NAME),Abraham Covenant)"; \
	SYMBOL_VAL="$(if $(ABRAHAM_SYMBOL),$(ABRAHAM_SYMBOL),COV)"; \
	echo "🔑 Deploying from: $$DEPLOYER_ADDRESS"; \
	echo ""; \
	node scripts/table-helper.js deployment abraham-covenant \
		"$(NETWORK)" \
		"$$NAME_VAL" \
		"$$SYMBOL_VAL" \
		"$$OWNER_VAL" \
		"$$ABRAHAM_VAL" \
		"$$MAX_SUPPLY_VAL" \
		"$$DAYS_WORK_VAL" \
		"$$INTERVAL_VAL"; \
	echo ""; \
	DEPLOY_KEY="$${ABRAHAM_PRIVATE_KEY:-$$PRIVATE_KEY}"; \
	HARDHAT_NETWORK=$(NETWORK) ABRAHAM_OWNER=$$OWNER_VAL ABRAHAM_ADDRESS=$$ABRAHAM_VAL ABRAHAM_MAX_SUPPLY=$$MAX_SUPPLY_VAL ABRAHAM_DAYS_OF_WORK=$$DAYS_WORK_VAL ABRAHAM_COMMIT_INTERVAL=$$INTERVAL_VAL ABRAHAM_NAME="$$NAME_VAL" ABRAHAM_SYMBOL=$$SYMBOL_VAL PRIVATE_KEY=$$DEPLOY_KEY \
	npx hardhat ignition deploy $(NFT_PATH)/DeployAbrahamCovenant.ts --deployment-id AbrahamCovenant-$(shell date +%s) --network $(NETWORK) --verify || true
	@node scripts/table-helper.js completion abraham-covenant
	$(call log-deployment,AbrahamCovenant)

deploy-abraham-auction: check-env
