# ========================================
# FOUNDRY / FORGE ENVIRONMENT VARIABLES
# ========================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control

# ----------------------------------------
# RPC Provider Configuration
# ----------------------------------------
# Alchemy, Infura, or other RPC provider API key
# Used for: forge script --rpc-url <network>
RPC_API_KEY=

# ----------------------------------------
# Deployment & Transaction Signing
# ----------------------------------------
# Private key for deployments and transactions
# Format: 0x... (with 0x prefix)
# IMPORTANT: Keep this secret! Never commit to git!
PRIVATE_KEY=

# ----------------------------------------
# Block Explorer API Keys
# ----------------------------------------
# For contract verification with --verify flag
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=

# ----------------------------------------
# Optional: Analytics & Monitoring
# ----------------------------------------
COINMARKETCAP_API_KEY=
OPENSEA_API_KEY=

# ----------------------------------------
# Deployment Configuration (Optional)
# ----------------------------------------
# Gepetto Toys NFT Deployment
COLLECTION_NAME="Brainrot Toys Collection"
COLLECTION_SYMBOL="TOY"
TOY_NAME="Brainrot Toy"
TOY_DESCRIPTION="Generated in Geppetto's Workshop"
TOY_OWNER=
PAYOUT_ADDRESS=0x34Ce568C936f03b5c416df0ce3b54d3CD5f4904e
ROYALTY_RECEIVER=
BASE_URI=https://vhswwkklyzbzvsoauisx.supabase.co/storage/v1/object/public/metadata/
